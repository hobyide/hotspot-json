  "source_tiers": {
    "tier_1_official": {
      "trust_level": 5,
      "can_confirm_alone": true,
      "description": "节目组、电视台、视频平台、制作公司、经纪公司、明星或工作室、品牌、法院、警方及其他正式发布主体"
    },
    "tier_2_platform_trend": {
      "trust_level": 3,
      "can_confirm_alone": false,
      "description": "用于计算热度和发现选题，不单独证明事件事实"
    },
    "tier_3_industry_media": {
      "trust_level": 3,
      "can_confirm_alone": false,
      "description": "白名单影视娱乐媒体；重要结论需要交叉验证"
    },
    "tier_4_search_fallback": {
      "trust_level": 1,
      "can_confirm_alone": false,
      "description": "仅在固定信源未覆盖时补源，必须经过域名、作者、时间、转载链和独立来源检查"
    }
