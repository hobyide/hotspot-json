ent rank engagement publish time or media URL"]}},"validation":{"json_parse":true,"schema":true,"source_id_referential_integrity":true,"fact_citation_support_check":true,"content_hash_deduplication":true,"file_size":true,"no_partial_commit_on_failure":true}}
