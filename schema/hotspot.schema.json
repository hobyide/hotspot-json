{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hobyide/hotspot-json/main/schema/hotspot.schema.json",
  "title": "Entertainment Hotspot Feed",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "feed",
    "generated_at",
    "timezone",
    "window_hours",
    "items",
    "source_status",
    "cleanup"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "feed": {
      "enum": [
        "all",
        "drama",
        "variety",
        "celebrity",
        "entertainment-events"
      ]
    },
    "generated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "timezone": {
      "const": "Asia/Shanghai"
    },
    "window_hours": {
      "type": "integer",
      "const": 24
    },
    "items": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "topic",
          "summary",
          "category",
          "language",
          "region",
          "hot_score",
          "first_seen_at",
          "last_seen_at",
          "trend",
          "entities",
          "verification",
          "sources",
          "media"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128
          },
          "topic": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "category": {
            "enum": [
              "drama",
              "variety",
              "celebrity",
              "relationship",
              "industry",
              "award_event",
              "controversy",
              "rating_performance",
              "entertainment_event"
            ]
          },
          "language": {
            "type": "string",
            "minLength": 2,
            "maxLength": 16
          },
          "region": {
            "type": "string",
            "minLength": 2,
            "maxLength": 16
          },
          "hot_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "first_seen_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_seen_at": {
            "type": "string",
            "format": "date-time"
          },
          "trend": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "cross_platform_count"
            ],
            "properties": {
              "status": {
                "enum": [
                  "new",
                  "rising",
                  "stable",
                  "falling",
                  "reappeared"
                ]
              },
              "cross_platform_count": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "entities": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "shows",
              "celebrities"
            ],
            "properties": {
              "shows": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 150
                }
              },
              "celebrities": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 100
                }
              }
            }
          },
          "verification": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "level",
              "official_source",
              "evidence_urls"
            ],
            "properties": {
              "status": {
                "enum": [
                  "official",
                  "confirmed",
                  "reported",
                  "unverified",
                  "refuted"
                ]
              },
              "level": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "official_source": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 200
              },
              "evidence_urls": {
                "type": "array",
                "uniqueItems": true,
                "maxItems": 10,
                "items": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "platform",
                "source_type",
                "rank",
                "heat_raw",
                "title",
                "url",
                "captured_at"
              ],
              "properties": {
                "platform": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 50
                },
                "source_type": {
                  "enum": [
                    "platform_trend",
                    "official_account",
                    "official_api",
                    "media",
                    "community"
                  ]
                },
                "rank": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 1
                },
                "heat_raw": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "maxLength": 100
                },
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 300
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "captured_at": {
                  "type": "string",
                  "format": "date-time"
                }
              }
            }
          },
          "media": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "images",
              "videos"
            ],
            "properties": {
              "images": {
                "type": "array",
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "url",
                    "type",
                    "width",
                    "height"
                  ],
                  "properties": {
                    "url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "type": {
                      "enum": [
                        "thumbnail",
                        "official_poster",
                        "article_image",
                        "avatar"
                      ]
                    },
                    "width": {
                      "type": [
                        "integer",
                        "null"
                      ],
                      "minimum": 1
                    },
                    "height": {
                      "type": [
                        "integer",
                        "null"
                      ],
                      "minimum": 1
                    }
                  }
                }
              },
              "videos": {
                "type": "array",
                "maxItems": 3,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "page_url",
                    "embed_url",
                    "thumbnail_url",
                    "duration_seconds"
                  ],
                  "properties": {
                    "page_url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "embed_url": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "format": "uri"
                    },
                    "thumbnail_url": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "format": "uri"
                    },
                    "duration_seconds": {
                      "type": [
                        "integer",
                        "null"
                      ],
                      "minimum": 0
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "source_status": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "status",
          "item_count",
          "checked_at",
          "error"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "status": {
            "enum": [
              "ok",
              "degraded",
              "failed",
              "not_checked"
            ]
          },
          "item_count": {
            "type": "integer",
            "minimum": 0
          },
          "checked_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 500
          }
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "last_run_at",
        "status"
      ],
      "properties": {
        "last_run_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "status": {
          "enum": [
            "pending",
            "completed",
            "failed"
          ]
        }
      }
    }
  }
}
