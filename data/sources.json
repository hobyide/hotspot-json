    {
      "source_id": "S0270713b59f2b7a9afb8",
      "title": "Sam Neill’s final interview: ‘I’d like to think that, in life, I’m a goodie’",
      "url": "https://www.theguardian.com/film/2026/jul/13/sam-neill-final-interview-readers-question-jurassic-park",
      "normalized_url": "https://www.theguardian.com/film/2026/jul/13/sam-neill-final-interview-readers-question-jurassic-park",
      "source": "theguardian.com",
      "source_type": "industry_media",
      "tier": "tier_3_industry_media",
      "author": null,
      "published_at": "2026-07-13T19:08:36+08:00",
